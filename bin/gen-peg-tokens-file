#!/usr/bin/env python

# import tokenizer
import tokenize, os

FILE_PATH = os.path.abspath(__file__)
DIR_PATH = os.path.dirname(FILE_PATH)

target_dir_path = DIR_PATH + '/../test/Unit/Compiler/Frontend/Peg/test-data/GrammarLexerTest'
file = open(target_dir_path + '/peg.peg')
tokengen = tokenize.generate_tokens(file.readline)

tokens_file_path = target_dir_path + '/peg-tokens'
with open(tokens_file_path, 'w') as f:
    f.write('# Generated by ' + os.path.basename(FILE_PATH) + '\n')
    for token in tokengen:
        f.write(repr(token) + "\n")
print("Written file: '{0}'".format(tokens_file_path))
