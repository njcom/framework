#!/usr/bin/env python
import sys
import tokenize


def process(readline) -> None:
    for token in tokenize.generate_tokens(readline):
        print(token)


if len(sys.argv) <= 1:
    process(sys.stdin.readline)
else:
    for arg in sys.argv[1:]:
        if arg == '-':
            process(sys.stdin.readline)
        else:
            with open(arg, 'r') as f:
                process(f.readline)
